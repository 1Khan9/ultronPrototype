# Ultron environment configuration
# Copy this file to .env and fill in your values.
# No secrets are required for the base prototype, but this file is structured
# for future capabilities (API keys for tools, smart home creds, etc.).

# Optional: override the audio input device by name substring
# ULTRON_AUDIO_DEVICE=

# Optional: route speech output to a headset/speakers by name substring
# ULTRON_AUDIO_OUTPUT_DEVICE=

# TTS pacing: lower is faster, higher is slower
# ULTRON_TTS_LENGTH_SCALE=0.92

# RVC timbre shaping
# ULTRON_RVC_PITCH_SHIFT=-2
# ULTRON_RVC_INDEX_RATE=0.9
# ULTRON_RVC_PROTECT=0.2
# ULTRON_RVC_RMS_MIX_RATE=0.15
# ULTRON_RVC_FILTER_RADIUS=2

# Set false if the assistant interrupts itself through speaker/mic loopback
# ULTRON_BARGE_IN_ENABLED=true
# ULTRON_BARGE_IN_GRACE_SECONDS=0.5

# Higher beam size improves STT accuracy at a small latency cost
# ULTRON_WHISPER_BEAM_SIZE=5

# Optional: override log level (DEBUG, INFO, WARNING, ERROR)
# ULTRON_LOG_LEVEL=INFO

# Optional: override the LLM model path
# ULTRON_LLM_MODEL_PATH=models/qwen2.5-7b-instruct-q4_k_m.gguf
