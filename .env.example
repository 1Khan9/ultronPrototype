# Kenning environment configuration
# Copy this file to .env and fill in your values.
# No secrets are required for the base prototype, but this file is structured
# for future capabilities (API keys for tools, smart home creds, etc.).

# Optional: override the audio input device by name substring
# KENNING_AUDIO_DEVICE=

# Optional: route speech output to a headset/speakers by name substring
# KENNING_AUDIO_OUTPUT_DEVICE=

# TTS pacing: lower is faster, higher is slower
# KENNING_TTS_LENGTH_SCALE=0.92

# RVC timbre shaping
# KENNING_RVC_PITCH_SHIFT=-2
# KENNING_RVC_INDEX_RATE=0.9
# KENNING_RVC_PROTECT=0.2
# KENNING_RVC_RMS_MIX_RATE=0.15
# KENNING_RVC_FILTER_RADIUS=2

# Set false if the assistant interrupts itself through speaker/mic loopback.
# This gates only GENERAL barge-in (any wake word interrupts). The explicit
# "Ultron, stop" command stays on independently via KENNING_STOP_COMMAND_ENABLED.
# KENNING_BARGE_IN_ENABLED=true
# KENNING_BARGE_IN_GRACE_SECONDS=0.5
# "Ultron, stop" all-channel interrupt -- always on; set false to disable.
# KENNING_STOP_COMMAND_ENABLED=true

# Auto push-to-talk for Valorant TEAM chat (PTT-only in game). Holds the in-game
# team-PTT key via an EXTERNAL USB-HID microcontroller (Arduino Leonardo) over
# serial while a relay line plays. DEFAULT OFF + fail-safe (no device -> inert,
# never falls back to synthetic input). To arm: flash firmware/leonardo_ptt,
# then set these on THIS machine (serial_port is your Leonardo's COM port).
# KENNING_PTT_ENABLED=true
# KENNING_PTT_SERIAL_PORT=COM5

# Higher beam size improves STT accuracy at a small latency cost
# KENNING_WHISPER_BEAM_SIZE=5

# Optional: override log level (DEBUG, INFO, WARNING, ERROR)
# KENNING_LOG_LEVEL=INFO

# Optional: override the LLM model path
# KENNING_LLM_MODEL_PATH=models/qwen2.5-7b-instruct-q4_k_m.gguf
